[Unit]
Description=Financial Architect Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/bot
EnvironmentFile=/opt/bot/.env
ExecStart=/usr/bin/python3 /opt/bot/main.py
Restart=always
RestartSec=10
StandardOutput=append:/var/log/tg-bot.log
StandardError=append:/var/log/tg-bot.log
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
