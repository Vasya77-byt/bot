[Unit]
Description=Financial Architect Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
WorkingDirectory=/opt/bot
EnvironmentFile=/opt/bot/.env
ExecStart=/opt/bot/.venv/bin/python /opt/bot/main.py
Restart=always
RestartSec=10
WatchdogSec=120
NotifyAccess=main
StandardOutput=append:/var/log/tg-bot.log
StandardError=append:/var/log/tg-bot.log
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
