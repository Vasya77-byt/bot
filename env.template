TG_API_ID=123456
TG_API_HASH=your_api_hash
TG_BOT_TOKEN=your_bot_token

# DaData.ru — базовые данные о компании
DADATA_API_KEY=your_dadata_api_key
DADATA_TIMEOUT=10

# API-FNS.ru — данные из ЕГРЮЛ
FNS_API_KEY=your_fns_api_key
FNS_TIMEOUT=15

# ФССП — проверка исполнительных производств
FSSP_API_KEY=your_fssp_api_key
FSSP_TIMEOUT=15

# СБИС — финансовые данные (опционально)
SBIS_LOGIN=your_sbis_login
SBIS_PASSWORD=your_sbis_password
SBIS_API_KEY=your_sbis_api_key
SBIS_CLIENT_ID=your_sbis_client_id
SBIS_BASE_URL=https://online.sbis.ru/service/?class=crm_ClaimsService&method=get_organization_info
SBIS_TIMEOUT=10
SBIS_MOCK=false
SBIS_RETRIES=2
SBIS_RETRY_DELAY=1.0
SBIS_CACHE_TTL=300
CACHE_DIR=.cache

SBIS_MOCK_PORT=8081

LOG_LEVEL=INFO
LOG_FORMAT=json  # json or plain

SENTRY_DSN=
SENTRY_ENV=dev
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_MAX_BREADCRUMBS=100
SENTRY_ATTACH_STACKTRACE=false

# Storage
STORAGE_DIR=storage
S3_BUCKET=
S3_PREFIX=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_ENDPOINT_URL=

# Metadata
METADATA_DIR=metadata

# Точка Банк — интернет-эквайринг
# JWT-токен из кабинета Точки (Настройки → Открытый API)
TOCHKA_JWT=
# Код клиента (УИД юрлица в Точке)
TOCHKA_CUSTOMER_CODE=
# ID торговой точки (опционально, если несколько)
TOCHKA_MERCHANT_ID=
# Для сандбокса: https://enter.tochka.com/sandbox/v2
TOCHKA_BASE_URL=https://enter.tochka.com/uapi
# Секрет для проверки подписи webhook'а (задаёте в кабинете)
TOCHKA_WEBHOOK_SECRET=

# URL возврата после оплаты (лучше — ссылка на бота: https://t.me/your_bot)
PAYMENT_REDIRECT_URL=https://t.me/
PAYMENT_FAIL_REDIRECT_URL=https://t.me/

# HTTP-сервер для приёма webhook'ов от Точки
# Точке нужен публичный HTTPS URL (например через Cloudflare Tunnel или nginx)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Хранилище платежей
PAYMENTS_FILE=payments.json

# Поддержка (Telegram username без @, например: my_support_bot)
SUPPORT_USERNAME=
